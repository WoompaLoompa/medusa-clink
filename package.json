{
  "name": "bitcoin-lightning-payment-module-for-medusajs-via-clink",
  "version": "1.0.0",
  "description": "Bitcoin Lightning payment module for Medusa eCommerce via the CLINK protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "publish:dry": "npm publish --dry-run",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@medusajs/framework": ">=2.0.0"
  },
  "dependencies": {
    "@shocknet/clink-sdk": "^1.5.5",
    "qrcode.react": "^4.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "license": "GPL-3.0",
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-payment",
    "bitcoin",
    "lightning",
    "lightning-network",
    "clink",
    "nostr",
    "payment-provider",
    "ecommerce",
    "bolt11",
    "self-custodial",
    "noffer",
    "ndebit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/WoompaLoompa/medusa-clink/"
  },
  "bugs": {
    "url": "https://github.com/WoompaLoompa/medusa-clink/issues"
  },
  "homepage": "https://github.com/WoompaLoompa/medusa-clink#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
